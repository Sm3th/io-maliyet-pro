{
  "name": "io-maliyet-pro",
  "version": "2.0.0",
  "description": "IO Software — Maliyet Pro | Profesyonel Maliyet Hesaplama",
  "main": "main.js",
  "author": {
    "name": "İsmet Organ",
    "url": "https://github.com/sm3th"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sm3th/io-maliyet-pro.git"
  },
  "homepage": "https://github.com/sm3th/io-maliyet-pro#readme",
  "bugs": {
    "url": "https://github.com/sm3th/io-maliyet-pro/issues"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.iosoftware.maliyetpro",
    "productName": "IO Maliyet Pro",
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IO Maliyet Pro"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ]
  }
}
